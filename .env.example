# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/medimate?appName=medimate

# JWT Secret (generate a strong random string for production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# App URL
NEXT_PUBLIC_APP_URL=https://medimate-app-git-master-kadiyambhanus-projects.vercel.app/

# Cloudinary (optional — falls back to local /public/uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Node Environment
NODE_ENV=development

# OCR — Google Cloud Vision (optional, preferred for OCR)
GOOGLE_VISION_API_KEY=your-google-vision-api-key

# AI Parsing — Google Gemini (required for prescription medicine extraction)
# Get a key from https://aistudio.google.com/apikey
# New auth keys start with AQ.; legacy standard keys start with AIzaSy...
# Do NOT use short-lived OAuth tokens (ya29.xxx) or gcloud access tokens here.
GEMINI_API_KEY=your-gemini-api-key-here

# Optional — defaults to gemini-2.5-flash with fallbacks
GEMINI_MODEL=gemini-2.5-flash
